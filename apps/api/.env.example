# Default Configuration (SQLite + MockRedis)

SERVER_PORT=7071
JWT_SECRET=supersecretkey
SWAGGER_PATH=swagger-api

USE_REAL_REDIS=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Local development does not require DATABASE_URL.
# To switch to MySQL:
# 1. Run `pnpm --filter @repo/database db:gen:mysql`
# 2. Set DATABASE_URL below
# DATABASE_URL="mysql://root:123456@localhost:3306/lumi-cms"

# Test-only helper. Keep disabled outside NODE_ENV=test.
DISABLE_CAPTCHA_FOR_TEST=false
