# Default local development uses SQLite in packages/database/prisma/dev.db
# Switch to MySQL only when you explicitly run `pnpm --filter @repo/database db:gen:mysql`
# and provide a DATABASE_URL.

SERVER_PORT=7071
JWT_SECRET=supersecretkey
SWAGGER_PATH=swagger-api

# Leave disabled for local development to use MockRedis.
USE_REAL_REDIS=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional: enable only when switching to MySQL
# DATABASE_URL="mysql://root:123456@localhost:3306/lumi-cms"

# Test-only helper. Do not enable in normal development.
DISABLE_CAPTCHA_FOR_TEST=false
